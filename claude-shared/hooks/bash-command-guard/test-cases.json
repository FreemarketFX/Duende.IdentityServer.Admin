  { "label": "acli + AILV via chained shell",                "command": "bash -c \"acli jira search 'project = AILV-99'\"", "expected": "block", "pattern": "(^|[^[:alnum:]_-])acli\\b.*AILV-[0-9]+|AILV-[0-9]+.*(^|[^[:alnum:]_-])acli\\b" },
  { "label": "AILV mention without acli (allow)",            "command": "echo 'AILV-7 is the ticket'",                     "expected": "allow", "pattern": null },
  { "label": "acli + AILV but boundary excludes (allow)",    "command": "local-acli-tools --ref AILV-42",                  "expected": "allow", "pattern": null },
