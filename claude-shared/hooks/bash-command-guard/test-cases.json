  { "command": "kubectl get pods",                           "expected": "block", "pattern": "\\bkubectl\\b" },
  { "command": "ksm secret get foo",                         "expected": "block", "pattern": "(^|[^[:alnum:]_-])ksm\\b" },
  { "command": "linux-ksm-tools status",                     "expected": "allow", "pattern": null },
  { "command": "static-swa-bin --version",                   "expected": "allow", "pattern": null },
