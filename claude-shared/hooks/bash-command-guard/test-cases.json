  { "command": "cat ~/.ssh/id_rsa",                          "expected": "block", "pattern": "\\.ssh/id_[a-z0-9_]+" },
  { "command": "cat ~/.aws/credentials",                     "expected": "block", "pattern": "\\.aws/credentials" },
  { "command": "cmdkey /list",                               "expected": "block", "pattern": "\\bcmdkey\\b" },
  { "command": "security find-generic-password -a foo",      "expected": "block", "pattern": "find-(\\w+)-password" },
  { "command": "gh auth token",                              "expected": "block", "pattern": "\\bgh\\s+auth\\s+token\\b" },
  { "command": "op read op://vault/item",                    "expected": "block", "pattern": "\\bop\\s+(read|item|document)\\b" },
  { "command": "aws sts get-session-token",                  "expected": "block", "pattern": "get-session-token" },
  { "command": "pass show github",                           "expected": "block", "pattern": "\\bpass\\s+show\\b" },
